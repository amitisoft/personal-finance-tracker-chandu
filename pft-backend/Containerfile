FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY src/Pft.Api/Pft.Api.csproj src/Pft.Api/Pft.Api.csproj
RUN dotnet restore src/Pft.Api/Pft.Api.csproj

COPY . .
RUN dotnet publish src/Pft.Api/Pft.Api.csproj -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build /app/publish .

ENV ASPNETCORE_URLS=http://0.0.0.0:8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "Pft.Api.dll"]
